{
  "name": "my-pocket",
  "version": "0.0.0",
  "private": true,
  "description": "Трекер расходов — монорепозиторий (Next.js + Nest.js + Prisma/PostgreSQL)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:frontend": "npm run dev --workspace @my-pocket/frontend",
    "dev:backend": "npm run start:dev --workspace @my-pocket/backend",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  }
}
